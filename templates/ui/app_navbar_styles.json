{
  "nav": {
    "align-items": "center",
    "background": "rgba(18,18,18,0.68)",
    "backdrop-filter": "blur(22px) saturate(160%)",
    "border-bottom": "1px solid rgba(255,255,255,0.08)",
    "display": "flex",
    "height": "2.875rem",
    "justify-content": "left",
    "padding-left": "2rem",
    "padding-right": "2rem",
    "position": "sticky",
    "top": "0",
    "width": "100%",
    "z-index": "1000"
  },
  "ul": {
    "display": "flex",
    "justify-content": "space-between",
    "width": "100%"
  },
  "li": {
    "align-items": "center",
    "display": "flex",
    "list-style": "none",
    "margin": "0 0.6rem",
    "height": "100%"
  },
  "a": {
    "text-decoration": "none",
    "color": "#fff",
    "display": "flex",
    "align-items": "center",
    "height": "100%"
  },
  "span": {
    "position": "relative",
    "border-radius": "0 0 18px 18px",
    "padding": "0.85rem 1.35rem",
    "font-weight": "600",
    "letter-spacing": "0.45px",
    "color": "rgba(255,255,255,0.96)",
    "background": "linear-gradient(180deg, rgba(255,255,255,0.45), rgba(255,255,255,0.25), rgba(255,255,255,0.15))",
    "backdrop-filter": "blur(18px) saturate(160%)",
    "-webkit-backdrop-filter": "blur(18px) saturate(160%)",
    "border": "1px solid rgba(255,255,255,0.28)",
    "border-top": "none",
    "box-shadow": "inset 0 1px 0 rgba(255,255,255,0.55), inset 0 -6px 10px rgba(0,0,0,0.18), 0 8px 22px rgba(0,0,0,0.48), 0 2px 6px rgba(0,0,0,0.32)",
    "transition": "transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease",
    "transform": "translateZ(0)",
    "will-change": "transform, box-shadow"
  },
  "active": {
    "background": "linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.20), rgba(255,255,255,0.12))",
    "box-shadow": "inset 0 6px 14px rgba(0,0,0,0.55), inset 0 -1px 0 rgba(255,255,255,0.25), 0 4px 10px rgba(0,0,0,0.45)",
    "transform": "translateY(2px) scale(0.97)"
  }
}
