{
  "html": {
    "background": "transparent !important",
    "background-color": "transparent !important"
  },
  "body": {
    "background": "transparent !important",
    "background-color": "transparent !important"
  },
  "*": {
    "background-color": "inherit !important"
  },
  "#root": {
    "background": "transparent !important",
    "background-color": "transparent !important"
  },
  ".ag-root": {
    "background": "linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.08))",
    "background-color": "transparent",
    "backdrop-filter": "blur(18px) saturate(160%)",
    "-webkit-backdrop-filter": "blur(18px) saturate(160%)",
    "border": "1px solid rgba(255, 255, 255, 0.28)",
    "border-radius": "8px",
    "overflow": "hidden",
    "box-shadow": "inset 0 1px 0 rgba(255,255,255,0.35), 0 8px 22px rgba(0,0,0,0.48)"
  },
  ".ag-header": {
    "background": "linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.12))",
    "border-bottom": "1px solid rgba(255, 255, 255, 0.2)",
    "backdrop-filter": "blur(18px) saturate(160%)"
  },
  ".ag-header-cell": {
    "background": "transparent",
    "color": "rgba(255, 255, 255, 0.96)",
    "font-weight": "600",
    "border-right": "1px solid rgba(255, 255, 255, 0.1)"
  },
  ".ag-row": {
    "background": "transparent",
    "border-bottom": "1px solid rgba(255, 255, 255, 0.08)"
  },
  ".ag-row:hover": {
    "background": "rgba(255, 255, 255, 0.15)",
    "transition": "background 0.2s ease",
    "backdrop-filter": "blur(8px)"
  },
  ".ag-row-selected": {
    "background": "rgba(80, 200, 180, 0.18) !important",
    "backdrop-filter": "blur(8px)",
    "border-left": "3px solid rgba(80, 200, 180, 0.6)"
  },
  ".ag-row-selected:hover": {
    "background": "rgba(80, 200, 180, 0.28) !important"
  },
  ".ag-cell": {
    "color": "rgba(255, 255, 255, 0.88)"
  }
}
